{
  "expo": {
    "name": "Thali",
    "slug": "thali",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./icons-png/thali-icon-ios_appstore_1024x1024.png",
    "scheme": "thali",
    "userInterfaceStyle": "light",

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.thali.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Thali uses the camera to scan QR codes at hotels.",
        "NSLocationWhenInUseUsageDescription": "Thali needs your location once to find hotels near you.",
        "NSNotificationsUsageDescription": "Thali sends you a reminder 2 hours before meal cutoff."
      }
    },
    "android": {
      "config": {
        "googleMaps": {
          "apiKey": "zndr5vQ6ppec6mmhaDDwRMNduO38ZtFmkqiZICy8"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./icons-png/thali-icon-android_playstore_512x512.png",
        "backgroundColor": "#1D9E75"
      },
      "package": "com.thali.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "SCHEDULE_EXACT_ALARM",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": false,
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "minSdkVersion": 26,
            "buildArchs": ["arm64-v8a"],
            "kotlinVersion": "2.1.20"
          }
        }
      ],
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Thali needs camera access to scan QR codes at hotels."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Thali needs your location once to find hotels near you.",
          "locationWhenInUsePermission": "Thali needs your location once to find hotels near you."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1D9E75"
        }
